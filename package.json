{
  "name": "opencode-antigravity-auth",
  "version": "2.2.0",
  "description": "Google Antigravity IDE OAuth auth plugin for Opencode - access Gemini 3 Pro and Claude 4.6 using Google credentials",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "license": "MIT",
    "author": "noefabris",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Acivar-Digital/opencode-antigravity-playbook.git"
    },
    "homepage": "https://github.com/Acivar-Digital/opencode-antigravity-playbook#readme",
    "bugs": {
        "url": "https://github.com/Acivar-Digital/opencode-antigravity-playbook/issues"
    },
    "keywords": [
        "opencode",
        "google",
        "antigravity",
        "gemini",
        "oauth",
        "plugin",
        "auth",
        "claude"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:schema": "npx tsx scripts/build-schema.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build",
        "test:e2e:models": "npx tsx scripts/test-models.ts",
        "test:e2e:regression": "npx tsx scripts/test-regression.ts"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^24.10.1",
        "@types/proper-lockfile": "^4.1.4",
        "@vitest/coverage-v8": "^3.0.0",
        "@vitest/ui": "^3.0.0",
        "typescript": "^5.0.0",
        "vitest": "^3.0.0",
        "zod-to-json-schema": "^3.25.1"
    },
    "dependencies": {
        "@openauthjs/openauth": "^0.4.3",
        "@opencode-ai/plugin": "^0.15.30",
        "better-sqlite3": "^12.10.1",
        "proper-lockfile": "^4.1.2",
        "xdg-basedir": "^5.1.0",
        "zod": "^4.0.0"
    }
}
